<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="hip_length" value="0.05"/>
  <xacro:property name="thigh_length" value="0.12"/>
  <xacro:property name="calf_length" value="0.12"/>
  
  <xacro:property name="hip_radius" value="0.025"/>
  <xacro:property name="thigh_radius" value="0.02"/>
  <xacro:property name="calf_radius" value="0.015"/>

  <xacro:property name="hip_mass" value="0.3"/>
  <xacro:property name="thigh_mass" value="0.4"/>
  <xacro:property name="calf_mass" value="0.3"/>

  <xacro:macro name="leg" params="leg_id parent origin_x origin_y origin_z reflect_y">
    
    <link name="${leg_id}_hip_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${hip_radius}" length="${hip_length}"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${hip_radius}" length="${hip_length}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${hip_mass}"/>
        <inertia ixx="0.001" ixy="0" ixz="0" 
                 iyy="0.001" iyz="0" 
                 izz="0.001"/>
      </inertial>
    </link>

    <joint name="${leg_id}_hip_joint" type="revolute">
      <parent link="${parent}"/>
      <child link="${leg_id}_hip_link"/>
      <origin xyz="${origin_x} ${origin_y} ${origin_z}" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-1.0" upper="1.0" effort="10" velocity="5"/>
    </joint>

    <link name="${leg_id}_thigh_link">
      <visual>
        <origin xyz="0 0 ${-thigh_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${thigh_radius}" length="${thigh_length}"/>
        </geometry>
        <material name="red"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-thigh_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${thigh_radius}" length="${thigh_length}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-thigh_length/2}" rpy="0 0 0"/>
        <mass value="${thigh_mass}"/>
        <inertia ixx="0.002" ixy="0" ixz="0" 
                 iyy="0.002" iyz="0" 
                 izz="0.0005"/>
      </inertial>
    </link>

    <joint name="${leg_id}_thigh_joint" type="revolute">
      <parent link="${leg_id}_hip_link"/>
      <child link="${leg_id}_thigh_link"/>
      <origin xyz="0 ${reflect_y * 0.04} 0" rpy="${reflect_y * 1.57} 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.5" upper="1.5" effort="15" velocity="8"/>
    </joint>

    <link name="${leg_id}_calf_link">
      <visual>
        <origin xyz="0 0 ${-calf_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${calf_radius}" length="${calf_length}"/>
        </geometry>
        <material name="green"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-calf_length/2}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${calf_radius}" length="${calf_length}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-calf_length/2}" rpy="0 0 0"/>
        <mass value="${calf_mass}"/>
        <inertia ixx="0.0015" ixy="0" ixz="0" 
                 iyy="0.0015" iyz="0" 
                 izz="0.0002"/>
      </inertial>
    </link>

    <joint name="${leg_id}_calf_joint" type="revolute">
      <parent link="${leg_id}_thigh_link"/>
      <child link="${leg_id}_calf_link"/>
      <origin xyz="0 0 ${-thigh_length}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.5" upper="-0.1" effort="15" velocity="8"/>
    </joint>

    <link name="${leg_id}_foot_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="0.02"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="0.02"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.05"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" 
                 iyy="0.00001" iyz="0" 
                 izz="0.00001"/>
      </inertial>
    </link>

    <joint name="${leg_id}_foot_joint" type="fixed">
      <parent link="${leg_id}_calf_link"/>
      <child link="${leg_id}_foot_link"/>
      <origin xyz="0 0 ${-calf_length}" rpy="0 0 0"/>
    </joint>

  </xacro:macro>

</robot>
